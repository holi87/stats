generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  matches   Match[]

  @@map("games")
}

model Player {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  matchesA  Match[]  @relation("PlayerA")
  matchesB  Match[]  @relation("PlayerB")
  ticketToRideMatchPlayers TicketToRideMatchPlayer[]
  multiplayerMatchPlayers MultiplayerMatchPlayer[]

  @@map("players")
}

model Match {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  playedOn  DateTime @map("played_on") @db.Date
  playerAId String   @map("player_a_id") @db.Uuid
  playerBId String   @map("player_b_id") @db.Uuid
  scoreA    Int      @map("score_a")
  scoreB    Int      @map("score_b")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  game      Game     @relation(fields: [gameId], references: [id])
  playerA   Player   @relation("PlayerA", fields: [playerAId], references: [id])
  playerB   Player   @relation("PlayerB", fields: [playerBId], references: [id])

  @@index([playedOn(sort: Desc)], map: "matches_played_on_desc_idx")
  @@index([gameId, playedOn(sort: Desc)], map: "matches_game_played_on_desc_idx")
  @@index([playerAId], map: "matches_player_a_idx")
  @@index([playerBId], map: "matches_player_b_idx")
  @@map("matches")
}

model TicketToRideVariant {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  matches   TicketToRideMatch[]
  multiplayerMatches MultiplayerTicketToRideMatch[]

  @@map("ticket_to_ride_variants")
}

model TicketToRideMatch {
  id        String   @id @default(uuid()) @db.Uuid
  playedOn  DateTime @map("played_on") @db.Date
  variantId String   @map("variant_id") @db.Uuid
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  variant   TicketToRideVariant @relation(fields: [variantId], references: [id])
  players   TicketToRideMatchPlayer[]

  @@map("ticket_to_ride_matches")
}

model TicketToRideMatchPlayer {
  id            String   @id @default(uuid()) @db.Uuid
  matchId       String   @map("match_id") @db.Uuid
  playerId      String   @map("player_id") @db.Uuid
  ticketsPoints Int      @map("tickets_points")
  bonusPoints   Int      @map("bonus_points")
  trainsCounts  Json     @map("trains_counts") @db.JsonB
  trainsPoints  Int      @map("trains_points")
  totalPoints   Int      @map("total_points")
  place         Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  match         TicketToRideMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player        Player       @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId], map: "ticket_to_ride_match_players_match_id_player_id_key")
  @@map("ticket_to_ride_match_players")
}

model MultiplayerGame {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  displayName String?  @map("display_name")
  scoringType String   @map("scoring_type")
  minPlayers  Int      @map("min_players")
  maxPlayers  Int      @map("max_players")
  isActive    Boolean? @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  matches     MultiplayerMatch[]

  @@map("multiplayer_games")
}

model MultiplayerMatch {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  playedOn  DateTime @map("played_on") @db.Date
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  game      MultiplayerGame @relation(fields: [gameId], references: [id])
  players   MultiplayerMatchPlayer[]
  ticketToRide MultiplayerTicketToRideMatch?

  @@index([gameId, playedOn(sort: Desc)], map: "multiplayer_matches_game_played_on_desc_idx")
  @@index([playedOn(sort: Desc)], map: "multiplayer_matches_played_on_desc_idx")
  @@map("multiplayer_matches")
}

model MultiplayerMatchPlayer {
  id          String   @id @default(uuid()) @db.Uuid
  matchId     String   @map("match_id") @db.Uuid
  playerId    String   @map("player_id") @db.Uuid
  totalPoints Int      @map("total_points")
  place       Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  match       MultiplayerMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      Player       @relation(fields: [playerId], references: [id])
  ticketToRideDetails MultiplayerTicketToRidePlayerDetail?
  terraformingMarsDetails MultiplayerTerraformingMarsPlayerDetail?

  @@unique([matchId, playerId], map: "multiplayer_match_players_match_id_player_id_key")
  @@index([playerId], map: "multiplayer_match_players_player_id_idx")
  @@index([matchId], map: "multiplayer_match_players_match_id_idx")
  @@map("multiplayer_match_players")
}

model MultiplayerTicketToRideMatch {
  matchId   String   @id @map("match_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid

  match     MultiplayerMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  variant   TicketToRideVariant @relation(fields: [variantId], references: [id])

  @@map("multiplayer_ticket_to_ride_matches")
}

model MultiplayerTicketToRidePlayerDetail {
  id            String   @id @default(uuid()) @db.Uuid
  matchPlayerId String   @unique @map("match_player_id") @db.Uuid
  ticketsPoints Int      @map("tickets_points")
  bonusPoints   Int      @map("bonus_points")
  trainsCounts  Json     @map("trains_counts") @db.JsonB
  trainsPoints  Int      @map("trains_points")

  matchPlayer   MultiplayerMatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("multiplayer_ticket_to_ride_player_details")
}

model MultiplayerTerraformingMarsPlayerDetail {
  id                 String   @id @default(uuid()) @db.Uuid
  matchPlayerId      String   @unique @map("match_player_id") @db.Uuid
  titlesCount        Int      @default(0) @map("titles_count")
  awardsFirstCount   Int      @default(0) @map("awards_first_count")
  awardsSecondCount  Int      @default(0) @map("awards_second_count")
  citiesPoints       Int      @default(0) @map("cities_points")
  forestsPoints      Int      @default(0) @map("forests_points")
  cardsPoints        Int      @default(0) @map("cards_points")
  trPoints           Int      @default(0) @map("tr_points")
  titlesPoints       Int      @default(0) @map("titles_points")
  awardsFirstPoints  Int      @default(0) @map("awards_first_points")
  awardsSecondPoints Int      @default(0) @map("awards_second_points")

  matchPlayer        MultiplayerMatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("multiplayer_terraforming_mars_player_details")
}
