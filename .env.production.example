POSTGRES_DB=gamestats
POSTGRES_USER=gamestats
POSTGRES_PASSWORD=change-me

BACKEND_PORT=3002
FRONTEND_PORT=5173

NODE_ENV=production
DB_BOOTSTRAP=false
DATABASE_URL=postgresql://gamestats:change-me@postgres:5432/gamestats
VITE_API_BASE_URL=https://stats.sh.info.pl
CORS_ORIGIN=https://stats.sh.info.pl
JSON_BODY_LIMIT=2mb
ADMIN_TOKEN=change-me
ADMIN_IMPORT_MAX_BYTES=2097152
ADMIN_IMPORT_WRITE_LIMIT=5
ADMIN_IMPORT_WRITE_WINDOW_MS=300000
FEATURE_OLYMPIC_RANKING=true
FEATURE_SIMPLE_TM_MODE=true
FEATURE_MULTI_OPTIONS_MODE=true
FEATURE_ADMIN_DATA_EXPORT=true
FEATURE_ADMIN_DATA_IMPORT=false
FEATURE_ADMIN_DATA_IMPORT_APPLY=false
